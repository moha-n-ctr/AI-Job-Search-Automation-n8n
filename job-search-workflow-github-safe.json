      "parameters": {
        "jsCode": "const jobs = $json.jobs;\n\nconst unique = [];\nconst seen = new Set();\n\nfor (const job of jobs) {\n\n  const key = (\n    (job.company || \"\").trim().toLowerCase() +\n    \"|\" +\n    (job.title || \"\").trim().toLowerCase()\n  );\n\n  if (!seen.has(key)) {\n    seen.add(key);\n    unique.push(job);\n  }\n}\n\nreturn [\n  {\n    json: {\n      jobs: unique\n    }\n  }\n];"
      },
